# Development only (loaded by `next dev`, ignored by `next start` — the
# gateway-spawned production UI keeps using the primary endpoint on 6342).
# Point the dev UI at the gateway's "test" listener endpoint: its policy
# confines all requests to the stdtest index/user-data DBs, so UI
# development never touches the real databases and needs no manual DB
# selection.
PANOPTIKON_API_URL=http://127.0.0.1:6343
